{
  "version": 2,
  "builds": [
    {
      "src": "frontend/dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/client/assets/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "\/(favicon\\.svg|favicon\\.ico|logo\\.svg|logo192\\.png|logo512\\.png|manifest\\.json|robots\\.txt|fortune\\.jpg)",
      "dest": "/frontend/dist/client/$1"
    },
    {
      "src": "(.*)",
      "dest": "/frontend/dist/server/server.js"
    }
  ]
}
